# Server-only MySQL connection string (never use NEXT_PUBLIC_)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Leave unset (or set CMS_FORCE_FILE=1) to use built-in seed / .data/cms.json only.
DATABASE_URL=mysql://moses:moses@127.0.0.1:3306/mosesedem

# Force file/seed CMS and skip MySQL entirely (useful on Vercel if DB is unreachable)
# CMS_FORCE_FILE=1

# Admin dashboard (/admin) password
ADMIN_PASSWORD=change-me-to-a-strong-secret

# Groq API key for AI Moses chat
GROQ_API_KEY=

