# Neon Postgres (server-only — never use NEXT_PUBLIC_)
# Use the pooled connection string from the Neon dashboard.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Force file/seed CMS and skip Postgres (local offline / emergency only)
# CMS_FORCE_FILE=1

# Admin dashboard (/admin) password — set a strong value on Vercel
ADMIN_PASSWORD=change-me-to-a-strong-secret

# Groq API key for AI Moses chat
GROQ_API_KEY=

# Resend — contact form delivery (server-only)
# Domain mosesedem.me must be verified in the Resend dashboard.
RESEND_API_KEY=
# From address (display name + mailbox). Default: Moses Edem <moses@mosesedem.me>
CONTACT_FROM_EMAIL=Moses Edem <moses@mosesedem.me>
# Where new form submissions land. Default: moses@mosesedem.me
CONTACT_TO_EMAIL=moses@mosesedem.me
# Optional: fire-and-forget JSON webhook after successful email
# (Slack Incoming Webhook, Zapier, n8n, Make, custom CRM). Never blocks the user.
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Cloudinary unsigned upload for blog images in the rich editor
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
